{
	"storage": {
	  "file": {
		"path": "/vault/file"
	  }
	},
	"listener": [
	  {
		"tcp": {
		  "address": "0.0.0.0:8200",
		  "tls_cert_file": "/vault/config.d/vault.crt",
		  "tls_key_file": "/vault/config.d/vault.key",
		  "tls_min_version": "tls12"
		}
	  }
	],
	"default_lease_ttl": "168h",
	"max_lease_ttl": "720h",
	"ui": true,
	"log_level": "Debug"
}